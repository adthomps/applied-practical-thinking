# Node
node_modules/

# Build outputs
dist/
build/

# Env files
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
!.dev.vars.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VSCode
.vscode/

# OS
.DS_Store
Thumbs.db

