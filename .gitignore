.playwright-cli/
output/playwright/

# Generated validation report snapshots
reports/validation/LATEST*
apps/web/public/docs/design/validation/LATEST*
apps/web/public/docs/design/validation/*

# Generated report/output artifacts
reports/**/*
!reports/**/.gitignore
output/**/*
!output/**/.gitignore
